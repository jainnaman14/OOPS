                                     **MULTILEVELINHERITANCE IN CPP:-


#include<iostream>
using namespace std;    

//Multilevel Inheritance : process by which one class acquires the properties and behaviours of another class which is derived from another class

class Human{
    protected:
    string name;
};

class Person : public Human{
    protected:
    int age;
};

class Student : public Person{
    
    int roll_no;

    public:
    Student(string n,int a,int r){
        name = n;
        age = a;
        roll_no = r;
    }

void display()
{
    cout<<"Name : "<<name<<endl;
    cout<<"Age : "<<age<<endl;
    cout<<"Roll No : "<<roll_no<<endl;      

}
};

int main(){
    Student obj("Naman",22,1072);
    obj.display();
    return 0;
}


                                          **MULTIPLEINHERITANCE IN CPP:-

#include<iostream>
using namespace std;

//Multiple Inheritance : process by which one class acquires the properties and behaviours of more than one class

class Human{
    protected:
    string name;
};

class Person{
    protected:
    int age;
};  

class Student : public Human, public Person{
    int roll_no;
    public:
    Student(string n,int a,int r){
        name = n;
        age = a;
        roll_no = r;
    }
    void display(){
        cout<<name<<" "<<age<<" "<<roll_no;
    }
};

int main(){
    Student obj("Naman",22,1072); 
    obj.display();     
    return 0;
}


