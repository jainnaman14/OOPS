1."THIS" is a keyword.
2."THIS" is a pointer that stores the current address of an object.


**WHY WE USE??
-> When local data member name and original data member name is same.

REPRESENTATION:- (*this).name="NAMAN";
                OR this -> name;

                                                          **COPY CONSTRUCTOR IN CPP:-

#include<iostream>
using namespace std;

class student
{
    public:
    string name;
    int age;
    int roll_no;

    student(string name,int age,int roll_no){
        this->name=name;
        this->age=age;
        this->roll_no=roll_no;
        cout<<"copy constructor called"<<endl;
    }
    student(student &a){
    name = a.name;
    age = a.age;
    roll_no = a.roll_no;
    cout<<a.name<<endl<<a.age<<endl<<a.roll_no<<endl;
    }
//if &(ampersent) is in actual paramter then it will be address of operator. 
//if &(ampersent) is in formal parameter then it will be in call by reference.
};

int main(){
    student obj1("NAMAN",22,1072);
    student obj2(obj1);
}

