                                                          **CLASS IN CPP
#include <iostream>
using namespace std;

class Student{
public:
    string name;
    int roll_no;
    int age;


    void study(){
        cout<<name<<" is studying"<<endl;
    }
};

int main(){
    Student obj;
    //dot operator: access methods and properties of a class
    obj.name ="Naman";
    obj.age  =22;
    obj.study();
}



